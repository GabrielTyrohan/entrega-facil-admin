{
  "name": "entrega-admin",
  "private": true,
  "version": "1.0.9",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "./",
  "description": "Sistema de Gestão de Entregas",
  "author": "Corium",
  "overrides": {
    "js-yaml": "^4.1.0",
    "jspdf": "^4.2.1"
  },
  "build": {
    "appId": "com.entregafacil.admin",
    "productName": "Entrega Fácil Gestão",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "Entrega Facil Gestao.exe"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "GabrielTyrohan",
      "repo": "entrega-facil-admin",
      "private": true,
      "releaseType": "release"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:publish": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase-cache-helpers/postgrest-react-query": "^1.13.6",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/query-sync-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.23.26",
    "highcharts": "^12.4.0",
    "highcharts-react-official": "^3.2.3",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.460.0",
    "react": "19.1.0",
    "react-barcode": "^1.6.1",
    "react-dom": "19.1.0",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.13.2",
    "react-to-print": "^3.3.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@eslint/js": "^9.9.1",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tauri-apps/cli": "^2.9.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.9.1",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^9.0.1"
  }
}
