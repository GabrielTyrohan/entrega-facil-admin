{
  "name": "entrega-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "./",
  "description": "Sistema de Gestão de Entregas",
  "author": "Corium",
  "build": {
    "appId": "com.entregafacil.admin",
    "productName": "Entrega Fácil Admin",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "zip",
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "compression": "store",
    "nsis": {
      "oneClick": false
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5175 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase-cache-helpers/postgrest-react-query": "^1.13.6",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/query-sync-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.0",
    "html2pdf.js": "^0.12.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.460.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.9.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tauri-apps/cli": "^2.9.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.9.1",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^9.0.1"
  }
}
